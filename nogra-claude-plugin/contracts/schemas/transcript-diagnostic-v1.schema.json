{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plugin://nogra/contracts/schemas/transcript-diagnostic-v1.schema.json",
  "title": "Nogra Transcript Diagnostic v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generatedAt",
    "mode",
    "authority",
    "advisoryOnly",
    "blocking",
    "root",
    "transcript",
    "sessionId",
    "signalCount",
    "signals",
    "limitations",
    "controlEffects",
    "summary",
    "privacy",
    "persistence",
    "path"
  ],
  "properties": {
    "schema": {
      "const": "nogra.transcript.diagnostic.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "const": "explicit-diagnostic"
    },
    "authority": {
      "const": "none"
    },
    "advisoryOnly": {
      "const": true
    },
    "blocking": {
      "const": false
    },
    "root": {
      "type": "string",
      "minLength": 1
    },
    "transcript": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "id",
        "exists",
        "lines",
        "source"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "lines": {
          "type": "integer"
        },
        "source": {
          "enum": [
            "explicit-path",
            "session-anchor",
            "none"
          ]
        }
      }
    },
    "sessionId": {
      "type": "string"
    },
    "signalCount": {
      "type": "integer"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "observation",
          "evidence",
          "limitations"
        ],
        "properties": {
          "id": {
            "enum": [
              "stop_language_precedes_tool_use",
              "agent_tool_use_observed",
              "business_metric_language_without_source_cue",
              "truth_labels_absent"
            ]
          },
          "category": {
            "enum": [
              "lexical-cooccurrence",
              "tool-observation",
              "source-cue"
            ]
          },
          "observation": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "line",
                "role",
                "cue",
                "excerpt"
              ],
              "properties": {
                "line": {
                  "type": "integer"
                },
                "role": {
                  "type": "string"
                },
                "cue": {
                  "type": "string"
                },
                "excerpt": {
                  "type": "string"
                }
              }
            }
          },
          "limitations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "controlEffects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permission",
        "go",
        "routing",
        "dispatch",
        "evidenceLevel",
        "factLevel",
        "verdict"
      ],
      "properties": {
        "permission": {
          "const": "none"
        },
        "go": {
          "const": "not-inferred"
        },
        "routing": {
          "const": "unchanged"
        },
        "dispatch": {
          "const": "unchanged"
        },
        "evidenceLevel": {
          "const": "unchanged"
        },
        "factLevel": {
          "const": "unchanged"
        },
        "verdict": {
          "const": "none"
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "privacy": {
      "type": "string",
      "minLength": 1
    },
    "persistence": {
      "enum": [
        "preview",
        "saved"
      ]
    },
    "path": {
      "type": "string"
    }
  }
}
