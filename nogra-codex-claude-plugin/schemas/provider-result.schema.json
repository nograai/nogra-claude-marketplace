{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nogra Codex Provider Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "provider", "mode", "status", "summary", "answer", "rawOutputRef"],
  "properties": {
    "schema": {
      "const": "nogra.provider_result.v0"
    },
    "provider": {
      "const": "codex"
    },
    "mode": {
      "enum": ["consult", "review", "delegate", "gate"]
    },
    "status": {
      "enum": ["ok", "failed", "timeout", "unavailable"]
    },
    "summary": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "counterpoints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggestedNext": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rawOutputRef": {
      "type": "string"
    }
  }
}
